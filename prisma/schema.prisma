generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum HoldingFinish {
  NORMAL
  HOLO
  REVERSE
  WPROMO
}

enum HoldingEdition {
  UNLIMITED
  FIRST_EDITION
}

model Holding {
  id            String         @id @default(cuid())
  ownerId       String
  cardId        String
  cardName      String
  setName       String
  imageUrl      String?
  cardNumber    Int?
  setTotal      Int?
  grade         String         @default("RAW")
  finish        HoldingFinish  @default(NORMAL)
  edition       HoldingEdition @default(UNLIMITED)
  purchasePrice Float
  quantity      Int            @default(1)
  createdAt     DateTime       @default(now())

  snapshots PriceSnapshot[]

  @@unique([ownerId, cardId, grade, finish, edition])
  @@index([ownerId])
  @@index([ownerId, createdAt])
}

model PriceSnapshot {
  id         String   @id @default(cuid())
  ownerId    String
  holdingId  String
  value      Float
  capturedAt DateTime @default(now())

  holding Holding @relation(fields: [holdingId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([holdingId, capturedAt])
}
